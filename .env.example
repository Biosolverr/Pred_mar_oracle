# ─────────────────────────────────────────────────────────
#  Prediction Market Oracle — Environment Variables
#  Локально: deno run --allow-net --allow-env --unstable-kv --env main.ts
#  Deno Deploy: Settings → Environment Variables
# ─────────────────────────────────────────────────────────

# ── Groq — основной LLM (быстрый, бесплатный tier) ───────
# Получить: https://console.groq.com
# Модель: llama-3.1-8b-instant
GROQ_API_KEY=gsk_your_groq_key_here

# ── OpenRouter — fallback (два бесплатных варианта) ───────
# Получить: https://openrouter.ai
# Модель 1: openai/gpt-oss-120b:free
# Модель 2: google/gemma-4-31b-it:free
OPENROUTER_API_KEY=sk-or-your_openrouter_key_here

# ── Платформа ─────────────────────────────────────────────
OWNER_ADDRESS=your_username

# ── Data-агенты (ключи НЕ нужны) ─────────────────────────
# Agent 1: CoinGecko  https://api.coingecko.com
# Agent 2: Binance    https://api.binance.com
#
# Цепочка LLM Oracle (Agent 3):
# Groq → OpenRouter GPT-OSS-120B:free → Gemma 4 31B:free
